# Copy to .env (or .env.local) and fill in. Vite exposes only VITE_-prefixed vars.
VITE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_CHAIN_ID=43113
VITE_REGISTRY_ADDRESS=
VITE_VAULT_ADDRESS=
# Block the vault was deployed at. Event queries (position discovery) start here, never from
# genesis -- public RPC providers cap eth_getLogs to a small block range, so scanning a long-
# lived chain's full history in one call fails. Find it once via eth_getCode binary search or
# the deploy tx receipt; 0 is fine for a fresh local/dev chain with only a handful of blocks.
VITE_VAULT_DEPLOY_BLOCK=0
# Optional: show this address's position read-only before a wallet is connected (demo).
VITE_DEMO_ADDRESS=
