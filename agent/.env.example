# Copy to .env and fill in. Never commit .env.

# Chain / wallet
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# Hot wallet that is set as the vault's executionAgent. Holds only AVAX for gas — never user funds.
AGENT_PRIVATE_KEY=

# Deployed contract addresses
REGISTRY_ADDRESS=
VAULT_ADDRESS=

# Behavior
# Comma-separated strategy ids to mirror. Empty = all active strategies.
STRATEGY_IDS=
POLL_INTERVAL_MS=4000
# Block to start scanning strategy trades from. "latest" or a block number.
START_BLOCK=latest
# Block the vault was deployed at — follow indexing starts here (follows can predate START_BLOCK).
VAULT_DEPLOY_BLOCK=0
DEADLINE_SECS=300
# Ignore detected strategy trades smaller than this (tokenIn base units). 0 = no filter.
MIN_TRADE_WEI=0
# true = compute and log mirrored trades but never send transactions.
DRY_RUN=true
